{
  "productName": "Photo Sorter",
  "version": "3.1.0",
  "identifier": "com.photosorter.v3",
  "build": {
"beforeDevCommand": "npm run dev",
"beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Photo Sorter",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Photography",
    "shortDescription": "Fast, distraction-free photo culling",
    "longDescription": "Rate photos with 1/2/3, export, done. RAW support, gamepad, compare mode. Zero AI.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
